POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=singbox_manager

JWT_SECRET=change-this-long-random-jwt-secret
ENCRYPTION_KEY=change-this-32-byte-secret-value

# Optional bind settings. Keep postgres private unless you need external DB access.
POSTGRES_BIND=127.0.0.1:5432
BACKEND_BIND=0.0.0.0:8080
FRONTEND_BIND=0.0.0.0:4173
